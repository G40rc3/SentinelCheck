<IfModule mod_headers.c>
  # Ghost Protocol is a self-contained interactive toolkit.
  # The main site CSP remains strict; this folder allows only the inline styles/scripts used by the toolkit.
  Header always set Content-Security-Policy "default-src 'none'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'none'; frame-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'none'; object-src 'none'; upgrade-insecure-requests;"
  Header always set Cross-Origin-Resource-Policy "same-origin"
  Header always set Cross-Origin-Opener-Policy "same-origin"
  Header always set Cross-Origin-Embedder-Policy "unsafe-none"
</IfModule>
